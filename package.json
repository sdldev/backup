{
  "name": "manual-backup-saas-beta",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/shared",
    "packages/app",
    "packages/web"
  ],
  "scripts": {
    "dev": "bun --filter @backup-saas/app dev",
    "dev:app": "bun --filter @backup-saas/app dev",
    "dev:web": "bun --filter @backup-saas/web dev",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "lint": "bun run typecheck",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "resolutions": {
    "yaml": "2.8.4",
    "esbuild": "0.27.7"
  }
}
