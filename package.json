{
  "name": "manual-backup-saas-beta",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "packages/shared",
    "packages/app",
    "packages/web"
  ],
  "scripts": {
    "dev": "bun --filter @backup-saas/app dev",
    "dev:app": "bun --filter @backup-saas/app dev",
    "dev:web": "bun --filter @backup-saas/web dev",
    "lint": "bun run typecheck",
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test --parallel 1 --max-concurrency 1 packages/app packages/shared",
    "test:security": "bun run tests/security/run-security.ts --parallel 1 --max-concurrency 1",
    "security:routes": "bun run scripts/security/check-route-inventory.ts",
    "security:tenant-scope": "bun run scripts/security/check-tenant-scope.ts",
    "security:object-keys": "bun run scripts/security/check-object-key-leaks.ts",
    "security:rollback-notes": "bun run scripts/security/check-rollback-notes.ts",
    "test:integration": "bun test --parallel 1 --max-concurrency 1 tests/integration",
    "test:e2e": "bun test --parallel 1 --max-concurrency 1 tests/e2e",
    "worker:reconcile": "bun run scripts/worker-reconcile.ts",
    "db:migrate:test": "bun run scripts/db/migrate-test.ts",
    "db:seed:test": "bun run scripts/db/seed-test.ts",
    "db:reset:test": "bun run scripts/db/reset-test.ts",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@eslint/js": "^9.2.0",
    "@types/bun": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.2.0",
    "postgres": "^3.4.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.0.0"
  },
  "resolutions": {
    "yaml": "2.8.4",
    "esbuild": "0.27.7"
  }
}
