---
import DashboardShell from '../components/DashboardShell.astro';
import StatCard from '../components/dashboard/StatCard.astro';
import { Button } from '../components/ui/button';
import { apiFetch } from '../lib/api';
import { buildAppNavGroups } from '../lib/dashboard-nav';

const response = await apiFetch('/v1/workspaces', Astro.request);

if (response.status === 401) {
  return Astro.redirect('/login');
}

if (response.status === 503) {
  return Astro.redirect('/login?error=api_unavailable');
}

if (!response.ok) {
  return Astro.redirect('/login?error=workspace_load_failed');
}

const payload = (await response.json()) as {
  data: Array<{
    workspace: {
      id: string;
      name: string;
      slug: string;
      storage_status: string;
      onboarding_step: string;
    };
    membership: { role: string };
    plan: { slug: string; name: string };
  }>;
};

const hasRealWorkspaces = payload.data.length > 0;
const readyStorageCount = payload.data.filter((item) => item.workspace.storage_status === 'ready').length;
const firstWorkspace = payload.data[0]?.workspace;
---

<DashboardShell
  brandLabel="Manual Backup"
  brandName="Portal"
  pageTitle="Dashboard"
  sidebarNote=""
  navGroups={buildAppNavGroups(Astro.url.pathname)}
>
  <section class="grid gap-5">
    <div class="dashboard-hero rounded-2xl border p-8 shadow-xl shadow-slate-950/10 md:p-12">
      <div class="relative z-10 max-w-xl">
        <p class="text-sm font-medium text-primary-foreground/75">Index Dashboard</p>
        <h2 class="mt-5 text-4xl font-semibold tracking-tight md:text-5xl">Workspace overview</h2>
        <p class="mt-5 max-w-lg text-sm leading-6 text-primary-foreground/75">Pilih Workspace untuk masuk ke dashboard tenant, cek kesiapan Backup Storage, dan lanjutkan setup manual Backup.</p>
      </div>
    </div>

    <section class="grid gap-4 md:grid-cols-3" aria-label="Workspace summary">
      <StatCard label="Total Workspaces" value={payload.data.length}>
        <p class="text-xs text-muted-foreground">Tenant scopes available</p>
      </StatCard>
      <StatCard label="Storage Ready" value={readyStorageCount}>
        <p class="text-xs text-muted-foreground">Backup Storage provisioned</p>
      </StatCard>
      <StatCard label="Active Scope" value="Manual">
        <p class="text-xs text-muted-foreground">Phase 1 Backup mode</p>
      </StatCard>
    </section>

    <section class="grid gap-4 lg:grid-cols-2">
      <div class="rounded-2xl border bg-card/95 p-5 shadow-sm backdrop-blur ">
        <h2 class="text-lg font-semibold tracking-tight">Next action</h2>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">
          {hasRealWorkspaces ? 'Lanjutkan ke Workspace aktif untuk mengelola Project, Database Source, dan Backup.' : 'Buat Workspace pertama untuk memulai New Tenant Onboarding.'}
        </p>
        <div class="mt-5 flex flex-wrap gap-2">
          <Button asChild><a href={firstWorkspace ? `/workspace/${firstWorkspace.slug}` : '/app/new-workspace'}>{firstWorkspace ? 'Open Workspace' : 'Create Workspace'}</a></Button>
          <Button asChild variant="secondary"><a href="/app/workspaces">View Workspaces</a></Button>
        </div>
      </div>

      <div class="rounded-2xl border bg-card/95 p-5 shadow-sm backdrop-blur ">
        <h2 class="text-lg font-semibold tracking-tight">Backup scope</h2>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">Phase 1 mendukung manual Backup untuk MySQL-family dan PostgreSQL-family Database Sources. Schedule, notifications, dan webhooks masih Coming soon.</p>
      </div>
    </section>
  </section>
</DashboardShell>
