---
import DashboardShell from '../components/DashboardShell.astro';
import EmptyState from '../components/dashboard/EmptyState.astro';
import PageHeader from '../components/dashboard/PageHeader.astro';
import StatCard from '../components/dashboard/StatCard.astro';
import StatusBadge from '../components/dashboard/StatusBadge.astro';
import { Button } from '../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../components/ui/card';
import { apiFetch } from '../lib/api';

const response = await apiFetch('/v1/workspaces', Astro.request);

if (response.status === 401) {
  return Astro.redirect('/login');
}

if (response.status === 503) {
  return Astro.redirect('/login?error=api_unavailable');
}

if (!response.ok) {
  return Astro.redirect('/login?error=workspace_load_failed');
}

const payload = (await response.json()) as {
  data: Array<{
    workspace: {
      id: string;
      name: string;
      slug: string;
      storage_status: string;
      onboarding_step: string;
    };
    membership: { role: string };
    plan: { slug: string; name: string };
  }>;
};

const readyStorageCount = payload.data.filter((item) => item.workspace.storage_status === 'ready').length;
---

<DashboardShell
  brandLabel="Manual Backup"
  brandName="Portal"
  sidebarNote="Encrypted manual Backups for Projects and Database Sources."
  navItems={[{ href: '/app', label: 'Workspaces', active: true }, { href: '/app/new-workspace', label: 'New Workspace' }]}
>
  <PageHeader eyebrow="Workspace launcher" title="Your Workspaces" description="Choose tenant to manage Projects, Database Sources, Backups, and Audit Log.">
    <Button slot="actions" asChild>
      <a href="/app/new-workspace">Create Workspace</a>
    </Button>
  </PageHeader>

  <section class="grid gap-4 md:grid-cols-3" aria-label="Workspace summary">
    <StatCard label="Total Workspaces" value={payload.data.length} />
    <StatCard label="Storage Ready" value={readyStorageCount} />
    <StatCard label="Active Scope" value="Manual" />
  </section>

  <Card className="mt-6">
    <CardHeader>
      <CardTitle>Workspace list</CardTitle>
    </CardHeader>
    <CardContent>
      {
        payload.data.length === 0 ? (
          <EmptyState title="No Workspace yet" description="Create your first Workspace to configure Projects, Database Sources, and manual Backups.">
            <Button slot="action" asChild>
              <a href="/app/new-workspace">Create first Workspace</a>
            </Button>
          </EmptyState>
        ) : (
          <div class="grid gap-3">
            {payload.data.map((item) => (
              <article class="flex flex-col gap-3 rounded-lg border p-4 md:flex-row md:items-center md:justify-between">
                <div>
                  <a class="font-semibold hover:underline" href={`/workspace/${item.workspace.slug}`}>{item.workspace.name}</a>
                  <p class="mt-1 text-sm text-muted-foreground">{item.membership.role} · {item.plan.name} · onboarding {item.workspace.onboarding_step}</p>
                </div>
                <div class="flex flex-wrap items-center gap-2">
                  <StatusBadge status={item.workspace.storage_status} label={`Storage ${item.workspace.storage_status}`} />
                  <Button asChild variant="outline" size="sm">
                    <a href={`/workspace/${item.workspace.slug}`}>Open</a>
                  </Button>
                </div>
              </article>
            ))}
          </div>
        )
      }
    </CardContent>
  </Card>
</DashboardShell>
