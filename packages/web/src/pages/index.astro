---
export const prerender = true;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Manual Backup SaaS Beta</title>
    <link rel="stylesheet" href="/src/styles/dashboard.css" />
  </head>
  <body>
    <main class="marketing-shell">
      <nav class="marketing-nav">
        <a class="brand brand--light" href="/">
          <span class="brand__label">Manual Backup</span>
          <span class="brand__name">Portal</span>
        </a>
        <a class="button button--primary" href="/login">Sign in</a>
      </nav>

      <section class="hero-card">
        <p class="eyebrow">Manual Backup SaaS Beta</p>
        <h1>Encrypted manual Backups for agency Workspaces</h1>
        <p>Sign in with Google or GitHub, create Workspaces, configure Projects and Database Sources, run manual Backup Jobs, download retained Backup artifacts, and review Audit Logs.</p>
        <div class="actions">
          <a class="button button--primary" href="/login">Sign in</a>
          <a class="button" href="/app">Open app</a>
        </div>
      </section>

      <section class="grid grid--stats marketing-grid" aria-label="Phase 1 scope">
        <article class="card stat">
          <span class="stat__label">Backup mode</span>
          <span class="stat__value">Manual</span>
        </article>
        <article class="card stat">
          <span class="stat__label">Storage</span>
          <span class="stat__value">Encrypted</span>
        </article>
        <article class="card stat">
          <span class="stat__label">Audit</span>
          <span class="stat__value">Included</span>
        </article>
      </section>
    </main>
  </body>
</html>
