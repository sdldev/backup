---
import DashboardShell from '../../../../components/DashboardShell.astro';
import { API_BASE_URL, apiFetch } from '../../../../lib/api';

const { workspaceSlug, backupId } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);
if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) throw new Error('Failed to load Workspace');

const workspacePayload = (await workspaceResponse.json()) as { data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } } };
const { workspace, membership } = workspacePayload.data;

const backupResponse = await apiFetch(`/v1/workspaces/${workspace.id}/backups/${backupId}`, Astro.request);
if (backupResponse.status === 404) return Astro.redirect(`/workspace/${workspace.slug}/backups`);
if (!backupResponse.ok) throw new Error('Failed to load Backup');

const backupPayload = (await backupResponse.json()) as {
  data: {
    id: string;
    status: string;
    format: string;
    download_filename: string;
    encrypted_size_bytes: number;
    original_size_bytes: number | null;
    retention_expires_at: string;
    created_at: string;
  };
};
const backup = backupPayload.data;
const canDelete = membership.role === 'owner' || membership.role === 'admin';
const formatBytes = (bytes: number | null) => (bytes === null ? 'Unknown' : new Intl.NumberFormat('en', { notation: 'compact' }).format(bytes) + ' B');
const navItems = [
  { href: `/workspace/${workspace.slug}`, label: 'Dashboard' },
  { href: `/workspace/${workspace.slug}/onboarding`, label: 'Onboarding' },
  { href: `/workspace/${workspace.slug}/projects`, label: 'Projects' },
  { href: `/workspace/${workspace.slug}/backups`, label: 'Backups', active: true },
  { href: `/workspace/${workspace.slug}/settings/audit-log`, label: 'Audit Log' },
];
---


  
    <DashboardShell brandLabel="Workspace" brandName={workspace.name} sidebarNote={`${membership.role} · Backup detail`} navItems={navItems}>
        <header class="topbar">
          <div>
            <p class="eyebrow">Backup detail</p>
            <h1>{backup.download_filename}</h1>
            <p>Download uses a short-lived, session-bound, single-use token.</p>
          </div>
          <div class="actions">
            <a class="button" href={`/workspace/${workspace.slug}/backups`}>All Backups</a>
            <button class="button button--primary" type="button" id="download-backup" disabled={backup.status !== 'succeeded'}>Download</button>
            <button class="button" type="button" id="delete-backup" disabled={!canDelete || backup.status !== 'succeeded'}>Delete</button>
          </div>
        </header>

        <section class="grid grid--stats" aria-label="Backup summary">
          <article class="card stat">
            <span class="stat__label">Status</span>
            <span class="stat__value">{backup.status}</span>
            <span class={`badge ${backup.status === 'succeeded' ? 'badge--ok' : 'badge--warn'}`}>{backup.status}</span>
          </article>
          <article class="card stat">
            <span class="stat__label">Encrypted Size</span>
            <span class="stat__value">{formatBytes(backup.encrypted_size_bytes)}</span>
          </article>
          <article class="card stat">
            <span class="stat__label">Original Size</span>
            <span class="stat__value">{formatBytes(backup.original_size_bytes)}</span>
          </article>
        </section>

        <section class="grid grid--two" style="margin-top: 18px;">
          <article class="card">
            <h2>Artifact metadata</h2>
            <dl class="detail-list">
              <dt>Format</dt>
              <dd>{backup.format}</dd>
              <dt>Retention expires</dt>
              <dd>{backup.retention_expires_at}</dd>
              <dt>Created</dt>
              <dd>{backup.created_at}</dd>
              <dt>Backup ID</dt>
              <dd>{backup.id}</dd>
            </dl>
            <p id="download-message" role="status"></p>
          </article>

          <article class="card card--soft">
            <h2>Security notes</h2>
            <ul class="list">
              <li class="list-item">Object key and checksum are not exposed in UI.</li>
              <li class="list-item">Download token expires in 15 minutes.</li>
              <li class="list-item">Download token is bound to current User Account and session.</li>
              <li class="list-item">Backup delete is Owner/Admin only.</li>
            </ul>
          </article>
        </section>
    </DashboardShell>

    <script is:inline define:vars={{ apiBaseUrl: API_BASE_URL, workspaceId: workspace.id, backupId: backup.id, workspaceSlug: workspace.slug }}>
      const button = document.getElementById('download-backup');
      const message = document.getElementById('download-message');
      const deleteButton = document.getElementById('delete-backup');

      button?.addEventListener('click', async () => {
        message.textContent = 'Creating download link...';
        const response = await fetch(`${apiBaseUrl}/v1/workspaces/${workspaceId}/backups/${backupId}/download-requests`, {
          method: 'POST',
          credentials: 'include',
        });
        const payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error?.message ?? 'Download link could not be created';
          return;
        }
        window.location.href = payload.data.download_url;
      });

      deleteButton?.addEventListener('click', async () => {
        const confirmed = window.confirm('Delete this Backup? This marks the artifact deleted and blocks future downloads.');
        if (!confirmed) return;
        message.textContent = 'Deleting Backup...';
        const response = await fetch(`${apiBaseUrl}/v1/workspaces/${workspaceId}/backups/${backupId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        const payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error?.message ?? 'Backup could not be deleted';
          return;
        }
        window.location.href = `/workspace/${workspaceSlug}/backups`;
      });

    </script>
  

