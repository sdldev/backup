---
import DashboardShell from '../../../../components/DashboardShell.astro';
import { API_BASE_URL, apiFetch } from '../../../../lib/api';

const { workspaceSlug, backupId } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);
if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) return Astro.redirect('/login?error=load_failed');

const workspacePayload = (await workspaceResponse.json()) as { data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } } };
const { workspace, membership } = workspacePayload.data;

const backupResponse = await apiFetch(`/v1/workspaces/${workspace.id}/backups/${backupId}`, Astro.request);
if (backupResponse.status === 404) return Astro.redirect(`/workspace/${workspace.slug}/backups`);
if (!backupResponse.ok) return Astro.redirect('/login?error=load_failed');

const backupPayload = (await backupResponse.json()) as {
  data: {
    id: string;
    status: string;
    format: string;
    download_filename: string;
    encrypted_size_bytes: number;
    original_size_bytes: number | null;
    retention_expires_at: string;
    created_at: string;
  };
};
const backup = backupPayload.data;
const canDelete = membership.role === 'owner' || membership.role === 'admin';
const formatBytes = (bytes: number | null) => (bytes === null ? 'Unknown' : new Intl.NumberFormat('en', { notation: 'compact' }).format(bytes) + ' B');
const navItems = [
  { href: `/workspace/${workspace.slug}`, label: 'Dashboard' },
  { href: `/workspace/${workspace.slug}/onboarding`, label: 'Onboarding' },
  { href: `/workspace/${workspace.slug}/projects`, label: 'Projects' },
  { href: `/workspace/${workspace.slug}/backups`, label: 'Backups', active: true },
  { href: `/workspace/${workspace.slug}/settings/audit-log`, label: 'Audit Log' },
];
---


  
    <DashboardShell brandLabel="Workspace" brandName={workspace.name} sidebarNote={`${membership.role} · Backup detail`} navItems={navItems}>
        <header class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Backup detail</p>
            <h1>{backup.download_filename}</h1>
            <p>Download uses a short-lived, session-bound, single-use token.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="inline-flex h-9 items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-accent hover:text-accent-foreground disabled:pointer-events-none disabled:opacity-50" href={`/workspace/${workspace.slug}/backups`}>All Backups</a>
            <button class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 disabled:pointer-events-none disabled:opacity-50" type="button" id="download-backup" disabled={backup.status !== 'succeeded'}>Download</button>
            <button class="inline-flex h-9 items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-accent hover:text-accent-foreground disabled:pointer-events-none disabled:opacity-50" type="button" id="delete-backup" disabled={!canDelete || backup.status !== 'succeeded'}>Delete</button>
          </div>
        </header>

        <section class="grid gap-4 md:grid-cols-3" aria-label="Backup summary">
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Status</span>
            <span class="block text-3xl font-semibold tracking-tight">{backup.status}</span>
            <span class={`inline-flex rounded-md px-2.5 py-0.5 text-xs font-semibold text-white ${backup.status === 'succeeded' ? 'bg-emerald-500' : 'bg-amber-500'}`}>{backup.status}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Encrypted Size</span>
            <span class="block text-3xl font-semibold tracking-tight">{formatBytes(backup.encrypted_size_bytes)}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Original Size</span>
            <span class="block text-3xl font-semibold tracking-tight">{formatBytes(backup.original_size_bytes)}</span>
          </article>
        </section>

        <section class="grid gap-4 lg:grid-cols-2" class="mt-6">
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <h2>Artifact metadata</h2>
            <dl class="detail-list">
              <dt>Format</dt>
              <dd>{backup.format}</dd>
              <dt>Retention expires</dt>
              <dd>{backup.retention_expires_at}</dd>
              <dt>Created</dt>
              <dd>{backup.created_at}</dd>
              <dt>Backup ID</dt>
              <dd>{backup.id}</dd>
            </dl>
            <p id="download-message" role="status"></p>
          </article>

          <article class="rounded-xl border bg-muted/30 p-5 text-card-foreground shadow-sm">
            <h2>Security notes</h2>
            <ul class="grid gap-3">
              <li class="flex items-center justify-between gap-4 rounded-lg border p-3">Object key and checksum are not exposed in UI.</li>
              <li class="flex items-center justify-between gap-4 rounded-lg border p-3">Download token expires in 15 minutes.</li>
              <li class="flex items-center justify-between gap-4 rounded-lg border p-3">Download token is bound to current User Account and session.</li>
              <li class="flex items-center justify-between gap-4 rounded-lg border p-3">Backup delete is Owner/Admin only.</li>
            </ul>
          </article>
        </section>
    </DashboardShell>

    <script is:inline define:vars={{ apiBaseUrl: API_BASE_URL, workspaceId: workspace.id, backupId: backup.id, workspaceSlug: workspace.slug }}>
      const button = document.getElementById('download-backup');
      const message = document.getElementById('download-message');
      const deleteButton = document.getElementById('delete-backup');

      button?.addEventListener('click', async () => {
        message.textContent = 'Creating download link...';
        const response = await fetch(`${apiBaseUrl}/v1/workspaces/${workspaceId}/backups/${backupId}/download-requests`, {
          method: 'POST',
          credentials: 'include',
        });
        const payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error?.message ?? 'Download link could not be created';
          return;
        }
        window.location.href = payload.data.download_url;
      });

      deleteButton?.addEventListener('click', async () => {
        const confirmed = window.confirm('Delete this Backup? This marks the artifact deleted and blocks future downloads.');
        if (!confirmed) return;
        message.textContent = 'Deleting Backup...';
        const response = await fetch(`${apiBaseUrl}/v1/workspaces/${workspaceId}/backups/${backupId}`, {
          method: 'DELETE',
          credentials: 'include',
        });
        const payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error?.message ?? 'Backup could not be deleted';
          return;
        }
        window.location.href = `/workspace/${workspaceSlug}/backups`;
      });

    </script>
  

