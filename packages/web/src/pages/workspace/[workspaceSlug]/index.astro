---
import DashboardShell from '../../../components/DashboardShell.astro';
import PageHeader from '../../../components/dashboard/PageHeader.astro';
import StatCard from '../../../components/dashboard/StatCard.astro';
import StatusBadge from '../../../components/dashboard/StatusBadge.astro';
import { Button } from '../../../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../../../components/ui/card';
import { apiFetch } from '../../../lib/api';

const { workspaceSlug } = Astro.params;
const response = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);

if (response.status === 401) return Astro.redirect('/login');
if (response.status === 404) return Astro.redirect('/app');
if (!response.ok) return Astro.redirect('/login?error=load_failed');

const payload = (await response.json()) as {
  data: {
    workspace: { id: string; name: string; slug: string; storage_status: string; onboarding_step: string };
    membership: { role: string };
    plan: { name: string };
  };
};

const { workspace, membership, plan } = payload.data;
const storageReady = workspace.storage_status === 'ready';
const navItems = [
  { href: `/workspace/${workspace.slug}`, label: 'Dashboard', active: true },
  { href: `/workspace/${workspace.slug}/onboarding`, label: 'Onboarding' },
  { href: `/workspace/${workspace.slug}/projects`, label: 'Projects' },
  { href: `/workspace/${workspace.slug}/backups`, label: 'Backups' },
  { href: `/workspace/${workspace.slug}/settings/audit-log`, label: 'Audit Log' },
];
---

<DashboardShell brandLabel="Workspace" brandName={workspace.name} sidebarNote={`${membership.role} · ${plan.name}`} navItems={navItems}>
  <PageHeader eyebrow="Manual Backup dashboard" title={workspace.name} description="Monitor storage readiness, setup progress, and next actions for encrypted manual Backups.">
    <Button slot="actions" asChild variant="outline"><a href="/app">Switch Workspace</a></Button>
    <Button slot="actions" asChild><a href={`/workspace/${workspace.slug}/projects`}>Manage Projects</a></Button>
  </PageHeader>

  <section class="grid gap-4 md:grid-cols-3" aria-label="Workspace health">
    <StatCard label="Storage" value={workspace.storage_status}>
      <StatusBadge status={storageReady ? 'ready' : 'needs_action'} label={storageReady ? 'Ready' : 'Needs action'} />
    </StatCard>
    <StatCard label="Plan" value={plan.name} />
    <StatCard label="Role" value={membership.role} />
  </section>

  <section class="mt-6 grid gap-4 lg:grid-cols-[1.3fr_0.7fr]">
    <Card>
      <CardHeader><CardTitle>Backup operations</CardTitle></CardHeader>
      <CardContent className="space-y-4">
        <p class="text-sm leading-6 text-muted-foreground">Setup progress, last Backup status, storage usage, and active Database Source count will appear here.</p>
        <div class="flex flex-wrap gap-2">
          <Button asChild><a href={`/workspace/${workspace.slug}/projects`}>Add Database Source</a></Button>
          <Button asChild variant="outline"><a href={`/workspace/${workspace.slug}/backups`}>View Backups</a></Button>
        </div>
      </CardContent>
    </Card>
    <Card className="bg-muted/30">
      <CardHeader><CardTitle>Next actions</CardTitle></CardHeader>
      <CardContent>
        <ul class="grid gap-2 text-sm text-muted-foreground">
          <li class="rounded-lg border bg-background p-3"><a class="font-medium text-foreground hover:underline" href={`/workspace/${workspace.slug}/projects`}>Create Project</a></li>
          <li class="rounded-lg border bg-background p-3">Add Database Source</li>
          <li class="rounded-lg border bg-background p-3">Run first manual Backup</li>
          <li class="rounded-lg border bg-background p-3">Review Audit Log</li>
        </ul>
      </CardContent>
    </Card>
  </section>
</DashboardShell>
