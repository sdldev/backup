---
import DashboardShell from '../../../components/DashboardShell.astro';
import { apiFetch } from '../../../lib/api';

const { workspaceSlug } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);
if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) throw new Error('Failed to load Workspace');

const workspacePayload = (await workspaceResponse.json()) as {
  data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } };
};
const { workspace, membership } = workspacePayload.data;

const backupsResponse = await apiFetch(`/v1/workspaces/${workspace.id}/backups`, Astro.request);
if (!backupsResponse.ok) throw new Error('Failed to load Backups');

const backupsPayload = (await backupsResponse.json()) as {
  data: Array<{
    id: string;
    status: string;
    format: string;
    download_filename: string;
    encrypted_size_bytes: number;
    original_size_bytes: number | null;
    retention_expires_at: string;
    created_at: string;
  }>;
};

const retainedBackupCount = backupsPayload.data.filter((backup) => backup.status === 'succeeded').length;
const totalEncryptedBytes = backupsPayload.data.reduce((total, backup) => total + backup.encrypted_size_bytes, 0);
const formatBytes = (bytes: number) => new Intl.NumberFormat('en', { notation: 'compact' }).format(bytes) + ' B';
const navItems = [
  { href: `/workspace/${workspace.slug}`, label: 'Dashboard' },
  { href: `/workspace/${workspace.slug}/onboarding`, label: 'Onboarding' },
  { href: `/workspace/${workspace.slug}/projects`, label: 'Projects' },
  { href: `/workspace/${workspace.slug}/backups`, label: 'Backups', active: true },
  { href: `/workspace/${workspace.slug}/settings/audit-log`, label: 'Audit Log' },
];
---


  
    <DashboardShell brandLabel="Workspace" brandName={workspace.name} sidebarNote={`${membership.role} · Backup history`} navItems={navItems}>
        <header class="topbar">
          <div>
            <p class="eyebrow">Backup history</p>
            <h1>{workspace.name}</h1>
            <p>Browse retained Backup artifacts. Object keys and checksums stay hidden from UI.</p>
          </div>
          <div class="actions">
            <a class="button button--primary" href={`/workspace/${workspace.slug}/projects`}>Run Backup from Source</a>
          </div>
        </header>

        <section class="grid grid--stats" aria-label="Backup summary">
          <article class="card stat">
            <span class="stat__label">Backups</span>
            <span class="stat__value">{backupsPayload.data.length}</span>
          </article>
          <article class="card stat">
            <span class="stat__label">Retained</span>
            <span class="stat__value">{retainedBackupCount}</span>
          </article>
          <article class="card stat">
            <span class="stat__label">Encrypted Size</span>
            <span class="stat__value">{formatBytes(totalEncryptedBytes)}</span>
          </article>
        </section>

        <section class="card" style="margin-top: 18px;">
          <h2>Backup list</h2>
          {
            backupsPayload.data.length === 0 ? (
              <div class="empty">
                <h2>No Backup yet</h2>
                <p>Run a manual Backup from an enabled Database Source.</p>
                <a class="button button--primary" href={`/workspace/${workspace.slug}/projects`}>Open Projects</a>
              </div>
            ) : (
              <ul class="list">
                {backupsPayload.data.map((backup) => (
                  <li class="list-item">
                    <div>
                      <a href={`/workspace/${workspace.slug}/backups/${backup.id}`}>
                        <strong>{backup.download_filename}</strong>
                      </a>
                      <p>{backup.format} · {formatBytes(backup.encrypted_size_bytes)} · expires {backup.retention_expires_at}</p>
                    </div>
                    <div class="actions">
                      <span class={`badge ${backup.status === 'succeeded' ? 'badge--ok' : 'badge--warn'}`}>{backup.status}</span>
                      <a class="button" href={`/workspace/${workspace.slug}/backups/${backup.id}`}>Open</a>
                    </div>
                  </li>
                ))}
              </ul>
            )
          }
        </section>
    </DashboardShell>
  

