---
import DashboardShell from '../../../components/DashboardShell.astro';
import { buildWorkspaceNavGroups } from '../../../lib/dashboard-nav';
import { apiFetch } from '../../../lib/api';

const { workspaceSlug } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);
if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) return Astro.redirect('/login?error=load_failed');

const workspacePayload = (await workspaceResponse.json()) as {
  data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } };
};
const { workspace, membership } = workspacePayload.data;

const backupsResponse = await apiFetch(`/v1/workspaces/${workspace.id}/backups`, Astro.request);
if (!backupsResponse.ok) return Astro.redirect('/login?error=load_failed');

const backupsPayload = (await backupsResponse.json()) as {
  data: Array<{
    id: string;
    status: string;
    format: string;
    download_filename: string;
    encrypted_size_bytes: number;
    original_size_bytes: number | null;
    retention_expires_at: string;
    created_at: string;
  }>;
};

const retainedBackupCount = backupsPayload.data.filter((backup) => backup.status === 'succeeded').length;
const totalEncryptedBytes = backupsPayload.data.reduce((total, backup) => total + backup.encrypted_size_bytes, 0);
const formatBytes = (bytes: number) => new Intl.NumberFormat('en', { notation: 'compact' }).format(bytes) + ' B';
---


  
    <DashboardShell brandLabel="Workspace" brandName={workspace.name} pageTitle="Backups" sidebarNote={`${membership.role} · Backup history`} navGroups={buildWorkspaceNavGroups(workspace.slug, Astro.url.pathname)}>
        <header class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Backup history</p>
            <h1>{workspace.name}</h1>
            <p>Browse retained Backup artifacts. Object keys and checksums stay hidden from UI.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 disabled:pointer-events-none disabled:opacity-50" href={`/workspace/${workspace.slug}/projects`}>Run Backup from Source</a>
          </div>
        </header>

        <section class="grid gap-4 md:grid-cols-3" aria-label="Backup summary">
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Backups</span>
            <span class="block text-3xl font-semibold tracking-tight">{backupsPayload.data.length}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Retained</span>
            <span class="block text-3xl font-semibold tracking-tight">{retainedBackupCount}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Encrypted Size</span>
            <span class="block text-3xl font-semibold tracking-tight">{formatBytes(totalEncryptedBytes)}</span>
          </article>
        </section>

        <section class="mt-6 rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
          <h2>Backup list</h2>
          {
            backupsPayload.data.length === 0 ? (
              <div class="empty">
                <h2>No Backup yet</h2>
                <p>Run a manual Backup from an enabled Database Source.</p>
                <a class="inline-flex h-9 items-center justify-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90 disabled:pointer-events-none disabled:opacity-50" href={`/workspace/${workspace.slug}/projects`}>Open Projects</a>
              </div>
            ) : (
              <ul class="grid gap-3">
                {backupsPayload.data.map((backup) => (
                  <li class="flex items-center justify-between gap-4 rounded-lg border p-3">
                    <div>
                      <a href={`/workspace/${workspace.slug}/backups/${backup.id}`}>
                        <strong>{backup.download_filename}</strong>
                      </a>
                      <p>{backup.format} · {formatBytes(backup.encrypted_size_bytes)} · expires {backup.retention_expires_at}</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                      <span class={`inline-flex rounded-md px-2.5 py-0.5 text-xs font-semibold text-white ${backup.status === 'succeeded' ? 'bg-emerald-500' : 'bg-amber-500'}`}>{backup.status}</span>
                      <a class="inline-flex h-9 items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-accent hover:text-accent-foreground disabled:pointer-events-none disabled:opacity-50" href={`/workspace/${workspace.slug}/backups/${backup.id}`}>Open</a>
                    </div>
                  </li>
                ))}
              </ul>
            )
          }
        </section>
    </DashboardShell>
  

