---
import DashboardShell from '../../../components/DashboardShell.astro';
import EmptyState from '../../../components/dashboard/EmptyState.astro';
import PageHeader from '../../../components/dashboard/PageHeader.astro';
import StatCard from '../../../components/dashboard/StatCard.astro';
import { Badge } from '../../../components/ui/badge';
import { Button } from '../../../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../../../components/ui/card';
import { buildWorkspaceNavGroups } from '../../../lib/dashboard-nav';
import { apiFetch } from '../../../lib/api';

const { workspaceSlug } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);
if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) return Astro.redirect('/login?error=load_failed');
const workspacePayload = (await workspaceResponse.json()) as { data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } } };
const { workspace, membership } = workspacePayload.data;
const backupsResponse = await apiFetch(`/v1/workspaces/${workspace.id}/backups`, Astro.request);
if (!backupsResponse.ok) return Astro.redirect('/login?error=load_failed');
const backupsPayload = (await backupsResponse.json()) as { data: Array<{ id: string; status: string; format: string; download_filename: string; encrypted_size_bytes: number; original_size_bytes: number | null; retention_expires_at: string; created_at: string }> };
const retainedBackupCount = backupsPayload.data.filter((backup) => backup.status === 'succeeded').length;
const totalEncryptedBytes = backupsPayload.data.reduce((total, backup) => total + backup.encrypted_size_bytes, 0);
const formatBytes = (bytes: number) => new Intl.NumberFormat('en', { notation: 'compact' }).format(bytes) + ' B';
---

<DashboardShell brandLabel="Workspace" brandName={workspace.name} pageTitle="Backups" sidebarNote={`${membership.role} · Backup history`} navGroups={buildWorkspaceNavGroups(workspace.slug, Astro.url.pathname)}>
  <PageHeader eyebrow="Backup history" title={workspace.name} description="Browse retained Backup artifacts. Object keys and checksums stay hidden from UI.">
    <Button slot="actions" asChild><a href={`/workspace/${workspace.slug}/projects`}>Run Backup from Source</a></Button>
  </PageHeader>
  <section class="grid gap-4 md:grid-cols-3" aria-label="Backup summary">
    <StatCard label="Backups" value={backupsPayload.data.length} />
    <StatCard label="Retained" value={retainedBackupCount} />
    <StatCard label="Encrypted Size" value={formatBytes(totalEncryptedBytes)} />
  </section>
  <Card className="mt-6">
    <CardHeader><CardTitle>Backup list</CardTitle></CardHeader>
    <CardContent>
      {backupsPayload.data.length === 0 ? (
        <EmptyState title="No Backup yet" description="Run a manual Backup from an enabled Database Source.">
          <Button slot="action" asChild><a href={`/workspace/${workspace.slug}/projects`}>Open Projects</a></Button>
        </EmptyState>
      ) : (
        <ul class="grid gap-3">
          {backupsPayload.data.map((backup) => (
            <li class="flex flex-col justify-between gap-4 rounded-lg border p-3 lg:flex-row lg:items-center">
              <div class="min-w-0">
                <a class="font-medium hover:underline" href={`/workspace/${workspace.slug}/backups/${backup.id}`}>{backup.download_filename}</a>
                <p class="text-sm text-muted-foreground">{backup.format} · {formatBytes(backup.encrypted_size_bytes)} · expires {backup.retention_expires_at}</p>
              </div>
              <div class="flex flex-wrap gap-2">
                <Badge variant="secondary">{backup.status}</Badge>
                <Button asChild variant="outline"><a href={`/workspace/${workspace.slug}/backups/${backup.id}`}>Open</a></Button>
              </div>
            </li>
          ))}
        </ul>
      )}
    </CardContent>
  </Card>
</DashboardShell>
