---
import DashboardShell from '../../../../components/DashboardShell.astro';
import EmptyState from '../../../../components/dashboard/EmptyState.astro';
import FormSection from '../../../../components/dashboard/FormSection.astro';
import PageHeader from '../../../../components/dashboard/PageHeader.astro';
import StatCard from '../../../../components/dashboard/StatCard.astro';
import { Badge } from '../../../../components/ui/badge';
import { Button } from '../../../../components/ui/button';
import { Card, CardContent, CardHeader, CardTitle } from '../../../../components/ui/card';
import { Field, FieldGroup, FieldLabel } from '../../../../components/ui/field';
import { Input } from '../../../../components/ui/input';
import { Select } from '../../../../components/ui/select';
import { buildWorkspaceNavGroups } from '../../../../lib/dashboard-nav';
import { apiFetch } from '../../../../lib/api';

const { workspaceSlug } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);

if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) return Astro.redirect('/login?error=load_failed');

const workspacePayload = (await workspaceResponse.json()) as {
  data: { workspace: { id: string; name: string; slug: string }; membership: { role: 'owner' | 'admin' | 'member' } };
};
const { workspace, membership } = workspacePayload.data;

const formData = Astro.request.method === 'POST' ? await Astro.request.formData() : null;
let formMessage = '';
let inviteLink = '';

if (formData) {
  const action = String(formData.get('action') ?? '');
  let response: Response | null = null;

  if (action === 'create-invite') {
    response = await apiFetch(`/v1/workspaces/${workspace.id}/invites`, Astro.request, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ email: String(formData.get('email') ?? ''), role: String(formData.get('role') ?? 'member') }),
    });
    if (response.ok) {
      const payload = (await response.json()) as { invite_token: string };
      inviteLink = `/invite/${payload.invite_token}`;
      formMessage = 'Invite created. Copy this link now; token is not stored in plaintext.';
    }
  }

  if (action === 'change-role') {
    const memberUserId = String(formData.get('member_user_id') ?? '');
    response = await apiFetch(`/v1/workspaces/${workspace.id}/members/${memberUserId}/role`, Astro.request, {
      method: 'PATCH',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ role: String(formData.get('role') ?? 'member') }),
    });
    if (response.ok) formMessage = 'Member role updated.';
  }

  if (action === 'remove-member') {
    const memberUserId = String(formData.get('member_user_id') ?? '');
    response = await apiFetch(`/v1/workspaces/${workspace.id}/members/${memberUserId}`, Astro.request, { method: 'DELETE' });
    if (response.ok) formMessage = 'Member removed.';
  }

  if (action === 'transfer-ownership') {
    response = await apiFetch(`/v1/workspaces/${workspace.id}/members/ownership-transfer`, Astro.request, {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ new_owner_user_id: String(formData.get('new_owner_user_id') ?? '') }),
    });
    if (response.ok) formMessage = 'Ownership transferred.';
  }

  if (response && !response.ok) {
    const payload = await response.json().catch(() => null);
    formMessage = payload?.error?.message ?? 'Member action failed.';
  }
}

const membersResponse = await apiFetch(`/v1/workspaces/${workspace.id}/members`, Astro.request);
if (!membersResponse.ok) return Astro.redirect('/login?error=load_failed');

const membersPayload = (await membersResponse.json()) as {
  data: Array<{
    id: string;
    user_id: string;
    role: 'owner' | 'admin' | 'member';
    joined_at: string;
    user?: { id: string; email: string; name: string; avatar_url: string | null };
  }>;
};

const ownerCount = membersPayload.data.filter((member) => member.role === 'owner').length;
const adminCount = membersPayload.data.filter((member) => member.role === 'admin').length;
const canManageMembers = membership.role === 'owner' || membership.role === 'admin';
const canTransferOwnership = membership.role === 'owner';
---

<DashboardShell brandLabel="Workspace" brandName={workspace.name} pageTitle="Members" sidebarNote={`${membership.role} · Team access`} navGroups={buildWorkspaceNavGroups(workspace.slug, Astro.url.pathname)}>
  <PageHeader eyebrow="Workspace settings" title="Members" description="Manage who can configure Database Sources, run Backups, and review sensitive Workspace activity.">
    <Button slot="actions" asChild variant="outline"><a href={`/workspace/${workspace.slug}/settings/audit-log`}>Audit Log</a></Button>
  </PageHeader>

  {formMessage ? (
    <Card className="mb-6">
      <CardContent className="pt-6">
        <strong>{formMessage}</strong>
        {inviteLink ? <p class="mt-2 break-all text-sm text-muted-foreground"><code>{new URL(inviteLink, Astro.url.origin).toString()}</code></p> : null}
      </CardContent>
    </Card>
  ) : null}

  <section class="grid gap-4 md:grid-cols-3" aria-label="Members summary">
    <StatCard label="Members" value={membersPayload.data.length} />
    <StatCard label="Owners" value={ownerCount} />
    <StatCard label="Admins" value={adminCount} />
  </section>

  {canManageMembers ? (
    <div class="mt-6">
      <FormSection title="Create invite" description="Invite token is shown once after creation.">
        <form method="post" class="flex flex-col gap-4">
          <input type="hidden" name="action" value="create-invite" />
          <FieldGroup>
            <Field>
              <FieldLabel htmlFor="invite-email">Email</FieldLabel>
              <Input id="invite-email" name="email" type="email" required placeholder="teammate@example.com" />
            </Field>
            <Field>
              <FieldLabel htmlFor="invite-role">Role</FieldLabel>
              <Select id="invite-role" name="role" defaultValue="member">
                <option value="member">Member</option>
                {membership.role === 'owner' ? <option value="admin">Admin</option> : null}
              </Select>
            </Field>
          </FieldGroup>
          <Button type="submit" variant="outline">Create invite</Button>
        </form>
      </FormSection>
    </div>
  ) : null}

  <Card className="mt-6">
    <CardHeader className="flex flex-row items-start justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Team access</p>
        <CardTitle className="mt-1">Workspace members</CardTitle>
      </div>
      <Badge variant="secondary">{canManageMembers ? 'Manage' : 'View only'}</Badge>
    </CardHeader>
    <CardContent>
      {membersPayload.data.length === 0 ? (
        <EmptyState title="No members yet" description="Workspace members will appear here after invites are accepted." />
      ) : (
        <ol class="grid gap-3">
          {membersPayload.data.map((member) => (
            <li class="flex flex-col justify-between gap-4 rounded-lg border p-3 lg:flex-row lg:items-center">
              <div class="min-w-0">
                <strong>{member.user?.name ?? member.user?.email ?? member.user_id}</strong>
                <p class="break-all text-sm text-muted-foreground">{member.user?.email ?? member.user_id} · joined {member.joined_at}</p>
              </div>
              <div class="flex flex-wrap items-center gap-2">
                <Badge variant="secondary">{member.role}</Badge>
                {membership.role === 'owner' && member.role !== 'owner' ? (
                  <form method="post" class="flex flex-wrap items-center gap-2">
                    <input type="hidden" name="action" value="change-role" />
                    <input type="hidden" name="member_user_id" value={member.user_id} />
                    <Select name="role" defaultValue={member.role} className="w-32">
                      <option value="member">Member</option>
                      <option value="admin">Admin</option>
                    </Select>
                    <Button type="submit" variant="outline">Update</Button>
                  </form>
                ) : null}
                {canManageMembers && member.role !== 'owner' ? (
                  <form method="post">
                    <input type="hidden" name="action" value="remove-member" />
                    <input type="hidden" name="member_user_id" value={member.user_id} />
                    <Button type="submit" variant="destructive">Remove</Button>
                  </form>
                ) : null}
              </div>
            </li>
          ))}
        </ol>
      )}
    </CardContent>
  </Card>

  {canTransferOwnership ? (
    <div class="mt-6">
      <FormSection title="Transfer ownership" description="Only admins can become the new Workspace Owner.">
        <form method="post" class="flex flex-col gap-4">
          <input type="hidden" name="action" value="transfer-ownership" />
          <FieldGroup>
            <Field>
              <FieldLabel htmlFor="new-owner-user-id">New Owner</FieldLabel>
              <Select id="new-owner-user-id" name="new_owner_user_id" required>
                {membersPayload.data.filter((member) => member.role === 'admin').map((member) => <option value={member.user_id}>{member.user?.email ?? member.user_id}</option>)}
              </Select>
            </Field>
          </FieldGroup>
          <Button type="submit" variant="outline">Transfer ownership</Button>
        </form>
      </FormSection>
    </div>
  ) : null}
</DashboardShell>
