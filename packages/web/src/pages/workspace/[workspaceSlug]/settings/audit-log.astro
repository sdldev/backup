---
import DashboardShell from '../../../../components/DashboardShell.astro';
import { apiFetch } from '../../../../lib/api';

const { workspaceSlug } = Astro.params;
const workspaceResponse = await apiFetch(`/v1/workspaces/by-slug/${workspaceSlug}`, Astro.request);

if (workspaceResponse.status === 401) return Astro.redirect('/login');
if (workspaceResponse.status === 404) return Astro.redirect('/app');
if (!workspaceResponse.ok) return Astro.redirect('/login?error=load_failed');

const workspacePayload = (await workspaceResponse.json()) as {
  data: { workspace: { id: string; name: string; slug: string }; membership: { role: string } };
};
const { workspace, membership } = workspacePayload.data;

const auditResponse = await apiFetch(`/v1/workspaces/${workspace.id}/audit-log`, Astro.request);
if (!auditResponse.ok) return Astro.redirect('/login?error=load_failed');

const auditPayload = (await auditResponse.json()) as {
  data: Array<{
    id: string;
    event_type: string;
    actor: { type: string; user_id: string | null };
    resource_type: string;
    resource_id: string | null;
    metadata: Record<string, unknown>;
    created_at: string;
  }>;
};

const userEventCount = auditPayload.data.filter((event) => event.actor.type === 'user').length;
const resourceTypeCount = new Set(auditPayload.data.map((event) => event.resource_type)).size;
const navItems = [
  { href: `/workspace/${workspace.slug}`, label: 'Dashboard' },
  { href: `/workspace/${workspace.slug}/onboarding`, label: 'Onboarding' },
  { href: `/workspace/${workspace.slug}/projects`, label: 'Projects' },
  { href: `/workspace/${workspace.slug}/backups`, label: 'Backups' },
  { href: `/workspace/${workspace.slug}/settings/audit-log`, label: 'Audit Log', active: true },
];
---


  
    <DashboardShell brandLabel="Workspace" brandName={workspace.name} sidebarNote={`${membership.role} · Security events`} navItems={navItems}>
        <header class="mb-6 flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-primary">Workspace settings</p>
            <h1>Audit Log</h1>
            <p>Review security and data-access events. Sensitive metadata is redacted before storage.</p>
          </div>
          <div class="flex flex-wrap gap-2">
            <a class="inline-flex h-9 items-center justify-center rounded-md border bg-background px-4 py-2 text-sm font-medium shadow-sm hover:bg-accent hover:text-accent-foreground disabled:pointer-events-none disabled:opacity-50" href={`/workspace/${workspace.slug}`}>Dashboard</a>
          </div>
        </header>

        <section class="grid gap-4 md:grid-cols-3" aria-label="Audit summary">
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Events</span>
            <span class="block text-3xl font-semibold tracking-tight">{auditPayload.data.length}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">User Actor Events</span>
            <span class="block text-3xl font-semibold tracking-tight">{userEventCount}</span>
          </article>
          <article class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
            <span class="text-sm font-medium text-muted-foreground">Resource Types</span>
            <span class="block text-3xl font-semibold tracking-tight">{resourceTypeCount}</span>
          </article>
        </section>

        <section class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm" class="mt-6">
          <h2>Latest events</h2>
          {
            auditPayload.data.length === 0 ? (
              <div class="empty">
                <h2>No Audit Log events yet</h2>
                <p>Security events will appear here after Workspace actions occur.</p>
              </div>
            ) : (
              <ol class="grid gap-3">
                {auditPayload.data.map((event) => (
                  <li class="flex items-center justify-between gap-4 rounded-lg border p-3">
                    <div>
                      <strong>{event.event_type}</strong>
                      <p>{event.created_at} · {event.actor.type} · {event.resource_type}</p>
                      <pre class="metadata-block">{JSON.stringify(event.metadata, null, 2)}</pre>
                    </div>
                    <span class="inline-flex rounded-md border bg-secondary px-2.5 py-0.5 text-xs font-semibold text-secondary-foreground">{event.resource_type}</span>
                  </li>
                ))}
              </ol>
            )
          }
        </section>
    </DashboardShell>
  

