---
import DashboardShell from '../../components/DashboardShell.astro';
import { API_BASE_URL, apiFetch } from '../../lib/api';

const sessionResponse = await apiFetch('/v1/session', Astro.request);
if (sessionResponse.status === 401) return Astro.redirect('/login');
if (!sessionResponse.ok) throw new Error('Failed to load session');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Create Workspace</title>
    <link rel="stylesheet" href="/src/styles/dashboard.css" />
  </head>
  <body>
    <DashboardShell
      brandLabel="Manual Backup"
      brandName="Portal"
      sidebarNote="Create tenant boundary for Projects, Database Sources, Backups, members, limits, and Audit Logs."
      navItems={[{ href: '/app', label: 'Workspaces' }, { href: '/app/new-workspace', label: 'New Workspace', active: true }]}
    >
      <header class="topbar">
        <div>
          <p class="eyebrow">New Tenant Onboarding</p>
          <h1>Create Workspace</h1>
          <p>Workspace groups Projects, Database Sources, Backups, members, plan limits, and Audit Logs.</p>
        </div>
        <div class="actions">
          <a class="button" href="/app">Back to Workspaces</a>
        </div>
      </header>

      <section class="grid grid--two">
        <article class="card">
          <h2>Workspace details</h2>
          <form id="workspace-form" class="form-grid">
            <label>
              Workspace name
              <input name="name" required maxlength="120" autocomplete="organization" placeholder="Agency or client name" />
            </label>
            <label>
              Workspace slug optional
              <input name="slug" maxlength="48" pattern="[a-z0-9-]+" placeholder="client-name" />
            </label>
            <label>
              Timezone
              <input name="timezone" required value="Asia/Jakarta" />
            </label>
            <label>
              Requested plan
              <select name="requested_plan">
                <option value="basic">Basic</option>
                <option value="pro">Pro request</option>
                <option value="agency">Agency request</option>
              </select>
            </label>
            <button class="button button--primary" type="submit">Create Workspace</button>
          </form>
          <p id="form-message" role="status"></p>
        </article>

        <article class="card card--soft">
          <h2>What happens next</h2>
          <ul class="list">
            <li class="list-item">Workspace is created on Basic plan.</li>
            <li class="list-item">Pro/Agency requests create pending plan request.</li>
            <li class="list-item">You become Workspace Owner.</li>
            <li class="list-item">Backup Storage can be provisioned from onboarding.</li>
          </ul>
        </article>
      </section>
    </DashboardShell>

    <script is:inline define:vars={{ apiBaseUrl: API_BASE_URL }}>
      const form = document.getElementById('workspace-form');
      const message = document.getElementById('form-message');

      form?.addEventListener('submit', async (event) => {
        event.preventDefault();
        message.textContent = 'Creating Workspace...';

        const formData = new FormData(form);
        const body = {
          name: String(formData.get('name') ?? ''),
          slug: String(formData.get('slug') ?? '') || undefined,
          timezone: String(formData.get('timezone') ?? ''),
          requested_plan: String(formData.get('requested_plan') ?? 'basic'),
        };

        const response = await fetch(`${apiBaseUrl}/v1/workspaces`, {
          method: 'POST',
          credentials: 'include',
          headers: { 'content-type': 'application/json' },
          body: JSON.stringify(body),
        });

        const payload = await response.json();
        if (!response.ok) {
          message.textContent = payload.error?.message ?? 'Workspace could not be created';
          return;
        }

        window.location.href = `/workspace/${payload.data.workspace.slug}/onboarding`;
      });
    </script>
  </body>
</html>
