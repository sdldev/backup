---
const { title, description } = Astro.props as { title: string; description?: string };
---

<section class="rounded-xl border bg-card p-5 text-card-foreground shadow-sm">
  <div class="mb-5 space-y-1">
    <h2 class="text-lg font-semibold tracking-tight">{title}</h2>
    {description ? <p class="text-sm leading-6 text-muted-foreground">{description}</p> : null}
  </div>
  <slot />
</section>
