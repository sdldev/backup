---
import '../styles/globals.css';
import { API_BASE_URL } from '../lib/api';
import AppSidebar from './dashboard/AppSidebar.astro';
import DashboardHeader from './dashboard/DashboardHeader.astro';
import { SidebarInset, SidebarProvider } from './ui/sidebar';

import type { DashboardNavGroup, DashboardNavItem } from '../lib/dashboard-nav';

const { brandLabel, brandName, navItems = [], navGroups, sidebarNote, pageTitle = 'Dashboard' } = Astro.props as {
  brandLabel: string;
  brandName: string;
  navItems?: DashboardNavItem[];
  navGroups?: DashboardNavGroup[];
  sidebarNote: string;
  pageTitle?: string;
};
---

<SidebarProvider client:load>
  <AppSidebar brandLabel={brandLabel} brandName={brandName} navItems={navItems} navGroups={navGroups} sidebarNote={sidebarNote} />
  <SidebarInset className="dashboard-surface min-w-0">
    <DashboardHeader pageTitle={pageTitle} />
    <main class="mx-auto w-full max-w-7xl p-4 md:p-6 lg:p-7">
      <slot />
    </main>
  </SidebarInset>
</SidebarProvider>

<script is:inline define:vars={{ apiBaseUrl: API_BASE_URL }}>
  document.querySelectorAll('[data-logout]').forEach((button) => {
    button.addEventListener('click', async () => {
      await fetch(`${apiBaseUrl}/v1/auth/logout`, { method: 'POST', credentials: 'include' });
      window.location.href = '/login';
    });
  });
</script>
