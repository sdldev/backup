---
import '../styles/globals.css';
import { API_BASE_URL } from '../lib/api';
import AppSidebar from './dashboard/AppSidebar.astro';
import DashboardHeader from './dashboard/DashboardHeader.astro';

type NavItem = {
  href: string;
  label: string;
  active?: boolean;
};

const { brandLabel, brandName, navItems, sidebarNote } = Astro.props as {
  brandLabel: string;
  brandName: string;
  navItems: NavItem[];
  sidebarNote: string;
};
---

<div class="min-h-screen bg-background text-foreground md:grid md:grid-cols-[260px_1fr]">
  <AppSidebar brandLabel={brandLabel} brandName={brandName} navItems={navItems} sidebarNote={sidebarNote} />
  <div class="min-w-0">
    <DashboardHeader />
    <main class="mx-auto w-full max-w-7xl p-4 md:p-6 lg:p-8">
      <slot />
    </main>
  </div>
</div>

<script is:inline define:vars={{ apiBaseUrl: API_BASE_URL }}>
  document.querySelector('[data-logout]')?.addEventListener('click', async () => {
    await fetch(`${apiBaseUrl}/v1/auth/logout`, { method: 'POST', credentials: 'include' });
    window.location.href = '/login';
  });
</script>
