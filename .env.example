# Runtime flags
API_ENABLED=true
WORKER_ENABLED=true
OBJECT_STORAGE_PROVIDER=local
OBJECT_STORAGE_LOCAL_DIR=.storage/backups
PORT=3000

# Database
DATABASE_URL=postgres://backup_saas:backup_saas@postgres:5432/backup_saas

# Auth/session
SESSION_COOKIE_NAME=backup_saas_session
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_DOMAIN=
DEV_SESSION_TOKEN=dev-session-token
DEV_INVITEE_SESSION_TOKEN=dev-invitee-session-token
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
WEB_BASE_URL=http://localhost:8080

# Encryption
# Generate: bun -e "console.log(Buffer.from(crypto.getRandomValues(new Uint8Array(32))).toString('base64url'))"
APP_MASTER_KEY_V1=

# Platform-managed S3-compatible storage
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=true

# Web
PUBLIC_API_BASE_URL=http://localhost:8080
INTERNAL_API_BASE_URL=http://app:3000
